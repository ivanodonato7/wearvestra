{
  "name": "vestra",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "scan:stock": "node scripts/scan-stock.js",
    "check:images": "node scripts/check-images.cjs",
    "check:images:deep": "node scripts/check-images.cjs --deep",
    "test:image-fallback": "node scripts/verify-image-fallback.mjs",
    "test:account-deletion": "node scripts/test-account-deletion.cjs",
    "test:cancel-pro-refund": "node scripts/test-cancel-pro-refund.cjs",
    "test:cancel-pro-refund-live": "node scripts/test-cancel-pro-refund-live.cjs",
    "deploy:netlify": "npm run build && npx netlify-cli deploy --prod --dir=dist --functions=netlify/functions",
    "netlify:env": "bash scripts/netlify-set-anthropic.sh",
    "cap:sync": "npm run build && npx cap sync",
    "cap:android": "npm run cap:sync && npx cap open android",
    "android": "npm run cap:sync && npx cap run android"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/app": "^8.1.1",
    "@capacitor/cli": "^8.4.2",
    "@capacitor/core": "^8.4.2",
    "@capacitor/splash-screen": "^8.0.2",
    "@capacitor/status-bar": "^8.0.3",
    "@netlify/blobs": "^10.7.9",
    "@supabase/supabase-js": "^2.110.7",
    "lucide-react": "^1.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "stripe": "^22.3.2"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "playwright": "^1.61.1",
    "vite": "^8.1.1",
    "vite-plugin-pwa": "^1.3.0"
  }
}
